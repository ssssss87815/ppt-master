{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Design tokens and UI guidance for the PPT Master workbench and productization surfaces.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.067,
          0.094,
          0.153
        ],
        "hex": "#111827"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.42,
          0.447,
          0.502
        ],
        "hex": "#6b7280"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.145,
          0.388,
          0.922
        ],
        "hex": "#2563eb"
      }
    },
    "neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.976,
          0.98,
          0.984
        ],
        "hex": "#f9fafb"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.02,
          0.588,
          0.412
        ],
        "hex": "#059669"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 10,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    }
  },
  "typography": {
    "h1": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 2.5,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        }
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "label-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 500
      }
    }
  }
}
